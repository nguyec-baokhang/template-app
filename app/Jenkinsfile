pipeline {
    agent {
        kubernetes {
            yaml '''
            spec:
              containers:
                - name: docker
                    image: docker:27-cli
                    tty: true
                    command:
                        - cat
                    volumeMounts:
                        - name: docker-sock
                            mountPath: /var/run/docker.sock
                - name: helm
                    image: dtzar/helm-kubectl:3.16.1
                    tty: true
                    command:
                        - cat
              volumes:
                - name: docker-sock
                    hostPath:
                        path: /var/run/docker.sock
            '''
                defaultContainer 'docker'
        }
    }

    environment {
        DOCKER_REPO = 'khangnguyen123/app-image'
        RELEASE_NAME = 'templateapp'
        NAMESPACE = 'dev'
        DOCKER_CREDENTIAL_ID = 'dockerhub-credentials'
        KUBECONFIG_CREDENTIAL_ID = 'minikube-kubeconfig'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.IMAGE_TAG = "${env.BUILD_NUMBER}"
                }
            }
        }

        stage('Build Image') {
            steps {
                container('docker') {
                    sh '''
                        docker version
                        docker build -f app/Dockerfile -t ${DOCKER_REPO}:${IMAGE_TAG} app
                    '''
                }
            }
        }

        stage('Push Image') {
            steps {
                container('docker') {
                    withCredentials([usernamePassword(credentialsId: "${DOCKER_CREDENTIAL_ID}", usernameVariable: 'DOCKER_USERNAME', passwordVariable: 'DOCKER_PASSWORD')]) {
                        sh '''
                            echo "${DOCKER_PASSWORD}" | docker login -u "${DOCKER_USERNAME}" --password-stdin
                            docker push ${DOCKER_REPO}:${IMAGE_TAG}
                            docker logout || true
                        '''
                    }
                }
            }
        }

        stage('Deploy to Minikube') {
            steps {
                container('helm') {
                    withCredentials([file(credentialsId: "${KUBECONFIG_CREDENTIAL_ID}", variable: 'KUBECONFIG')]) {
                        sh '''
                            kubectl config current-context
                            kubectl get nodes
                            helm upgrade --install ${RELEASE_NAME} ./app/helm \\
                              --namespace ${NAMESPACE} \\
                              --create-namespace \\
                              --set image.repository=${DOCKER_REPO} \\
                              --set image.tag=${IMAGE_TAG} \\
                              --set ingress.enabled=false \\
                              --wait --timeout=5m
                            kubectl -n ${NAMESPACE} get pods -l app.kubernetes.io/instance=${RELEASE_NAME}
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}